# Django 密钥（生产环境务必更换）
SECRET_KEY=your-secret-key-here

# 调试模式（生产环境设为 False）
DEBUG=True

# 允许的主机
ALLOWED_HOSTS=localhost,127.0.0.1

# 数据库引擎：sqlite（默认）/ mysql / postgresql
DB_ENGINE=sqlite

# 以下仅在 DB_ENGINE=mysql 或 postgresql 时需要
# DB_NAME=database
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=
